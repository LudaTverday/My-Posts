<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Posts</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="/styles/styles.css" rel="stylesheet">
</head>

<body class="pt-90 pb-60">
    <div class="container fixed-top bg-white ">
        <header class="d-flex flex-wrap justify-content-center py-1 ">
            <nav class="navbar navbar-expand-xl d-flex border-bottom align-items-center container-fluid">
                <a href="/"
                    class="navbar-brand d-flex  align-items-center mb-md-0 me-md-auto link-body-emphasis text-decoration-none">
                    <svg xmlns="http://www.w3.org/2000/svg" class="bi me-2" width="40" height="32" aria-hidden="true"
                        viewBox="0 0 200 200">
                        <rect width="200" height="200" rx="40" fill="#3B82F6" />
                        <text x="100" y="140" font-size="100" font-family="Arial, sans-serif" font-weight="bold"
                            fill="white" text-anchor="middle">MP</text>
                    </svg>
                    <span class="fs-4 ">My Posts</span>
                </a>



                <button class="navbar-toggler shadow-none" id="toggleMainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse " id="mainNavbar">
                    <ul class="nav  fs-17 ">
                        <li class="nav-item ms-auto ms-lg-0 "><a href="/" class="nav-link active fw-semibold"
                                aria-current="page">Home</a></li>
                        <li class="nav-item"><a href="/new_post" class="nav-link fs-17  <%= currentUrl === " /new_post"
                                ? "fw-medium" : "" %>">Create Post</a></li>
                        <li class="nav-item"><a href="/about" class="nav-link fs-17  <%= currentUrl === " /about"
                                ? "fw-medium" : "" %>">About</a></li>
                    </ul>
                </div>

            </nav>





            <nav class="navbar  border-bottom  <%= display %>  navbar-expand-xl">
                <div class="container ">
                    <!-- Toggle button - appears only on small screens -->
                    <button class="navbar-toggler btn btn-link border-0 shadow-none" id="toggleNavbarCategories">
                        <span>Categories
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                class="bi bi-chevron-down" viewBox="0 0 16 16">
                                <path fill-rule="evenodd"
                                    d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708" />
                            </svg>
                        </span>
                    </button>
                    <!-- Collapsible menu -->
                    <div class="collapse navbar-collapse justify-content-center" id="categories">
                        <ul class="nav ">
                            <% categories.forEach((categ)=> { %>
                                <li class="nav-item fs-17">
                                    <a href="/<%= categ === " Wrong Turns"? "Wrong_Turns" : categ %>"
                                        class="nav-link fs-20 <%= currentUrl===`/${categ==="Wrong Turns" ? "Wrong_Turns"
                                            : categ}` ? 'fw-medium' : '' %>" aria-current="page">
                                            <%=categ%>
                                    </a>
                                </li>
                                <% }) %>
                        </ul>
                    </div>

                </div>

            </nav>

        </header>
    </div>


    </div>